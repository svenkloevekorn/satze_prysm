# =========================================================
# Prysm – Produktions-Konfiguration (Mittwald)
# =========================================================
# Diese Datei als Vorlage nutzen, NICHT direkt deployen.
# Auf dem Server die echten Werte in `.env` eintragen.

APP_NAME="Prysm"
APP_ENV=production
APP_KEY=                                # mit `php artisan key:generate` erzeugen
APP_DEBUG=false
APP_URL=https://prysm.example.de        # finale Domain hier eintragen

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ------ Logging ------
LOG_CHANNEL=stack
LOG_STACK=daily                         # rotierende Tages-Logs (statt `single`)
LOG_LEVEL=error                         # nur Fehler ins Prod-Log
LOG_DEPRECATIONS_CHANNEL=null

# ------ Datenbank ------
DB_CONNECTION=pgsql
DB_HOST=                                # Mittwald-DB-Host (z.B. pgsql.pXXXXXX.mittwaldserver.info)
DB_PORT=5432
DB_DATABASE=                            # Mittwald-DB-Name (im mStudio angelegt)
DB_USERNAME=                            # Mittwald-DB-User
DB_PASSWORD=                            # Mittwald-DB-Passwort

# ------ Filament Impersonation ------
FILAMENT_IMPERSONATE_REDIRECT=/admin    # nach Impersonation direkt ins Admin-Panel

# ------ Session / Cache / Queue ------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local                   # oder "s3" falls Bilder in S3/R2 sollen
MEDIA_DISK=local                        # Spatie-MediaLibrary auf private Disk (signierte URLs)
QUEUE_CONNECTION=database

CACHE_STORE=database

# ------ Mail ------
MAIL_MAILER=smtp                        # Mittwald-SMTP oder eigener Provider
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@prysm.example.de"
MAIL_FROM_NAME="${APP_NAME}"

# ------ Optional: S3/R2 für Bilder ------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
